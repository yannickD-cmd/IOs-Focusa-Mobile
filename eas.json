{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_HOME": "/tmp/.expo"
      },
      "ios": {
        "simulator": false,
        "image": "latest"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_NO_CAPABILITY_SYNC": "1",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "ios": {
        "autoIncrement": "buildNumber"
      },
      "android": {
        "autoIncrement": "versionCode"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "yannick@trydeva.com",
        "ascAppId": "6757128057",
        "appleTeamId": "7M7HDM9435"
      }
    }
  }
}
